<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ChecklistApp.Controls"
             x:Class="ChecklistApp.Controls.Popup"
             x:DataType="controls:Popup">
    <ContentView.ControlTemplate>
        <ControlTemplate x:DataType="controls:Popup">
            <Grid IsClippedToBounds="False">
                <Border x:Name="overlay"
                        BackgroundColor="Black"
                        Opacity="{TemplateBinding Opacity}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{TemplateBinding CloseCommand}" />
                    </Border.GestureRecognizers>
                </Border>
                <FlexLayout Direction="Column"
                            AlignContent="Stretch"
                            JustifyContent="Center">
                    <Border x:Name="popup"
                            Margin="{TemplateBinding PopupMargin}"
                            Scale="{TemplateBinding Scale}"
                            BackgroundColor="{StaticResource Background}"
                            StrokeShape="RoundRectangle 14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer />
                        </Border.GestureRecognizers>
                        <ContentPresenter />
                    </Border>
                </FlexLayout>
            </Grid>
        </ControlTemplate>
    </ContentView.ControlTemplate>
</ContentView>