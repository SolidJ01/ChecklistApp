<?xml version="1.0" encoding="utf-8"?>

<controls:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ChecklistApp.Controls"
             xmlns:viewmodel="clr-namespace:ChecklistApp.ViewModel"
             x:Name="settings"
             x:Class="ChecklistApp.Controls.SettingsPopup"
             x:DataType="controls:SettingsPopup">
    <controls:Popup.Content>
        <Grid RowDefinitions="*, 70"
              BindingContext="{x:Reference settings}">
            <ScrollView>
                <VerticalStackLayout Padding="10" 
                                     Spacing="10">
                    <Label FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Text}"
                           Text="Default Settings"
                           HorizontalTextAlignment="Center"
                           Margin="0,10,0,0"/>
                    <controls:NotificationScheduler NotificationsEnabled="{Binding ViewModel.NotificationsEnabled}"
                                                    Notifications="{Binding ViewModel.Notifications}"/>
                </VerticalStackLayout>
            </ScrollView>
            <controls:ControlBar Grid.Row="1">
                <Grid ColumnDefinitions="50, *" 
                      ColumnSpacing="10">
                    <Button WidthRequest="50"
                            Text="&#xf060;"
                            FontFamily="FontAwSolid"
                            Clicked="CloseButtonClicked" />
                    <Button Grid.Column="1"
                            Text="Export Checklists"
                            Clicked="ExportButtonClicked"/>
                </Grid>
            </controls:ControlBar>
        </Grid>
    </controls:Popup.Content>
    
</controls:Popup>