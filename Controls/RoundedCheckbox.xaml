<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ChecklistApp.Controls"
             x:Name="this"
             x:Class="ChecklistApp.Controls.RoundedCheckbox"
             x:DataType="controls:RoundedCheckbox">
    <Grid BindingContext="{x:Reference this}">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="Button_Clicked" NumberOfTapsRequired="1" />
        </Grid.GestureRecognizers>
        <Border Margin="{Binding ClickablePadding}" 
                Padding="0"
                x:Name="BaseFrame">
            <Border.Triggers>
                <DataTrigger TargetType="Border" Binding="{Binding EnsureSquare}" Value="true">
                    <Setter Property="HeightRequest" Value="{Binding Width, Source={RelativeSource AncestorType={x:Type Grid}}}" />
                </DataTrigger>
                
                <DataTrigger TargetType="Border" 
                             Binding="{Binding ClickablePadding, Converter={StaticResource GreaterThanZero}}" 
                             Value="true">
                    <Setter Property="StrokeShape" Value="RoundRectangle 7" />
                </DataTrigger>
                
                <MultiTrigger TargetType="Border">
                    <MultiTrigger.Conditions>
                        <BindingCondition Binding="{Binding Design}" Value="DynamicForegroundDark" />
                        <BindingCondition Binding="{Binding IsChecked}" Value="false" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource ForegroundDarkBrush}" />
                </MultiTrigger>
                <MultiTrigger TargetType="Border">
                    <MultiTrigger.Conditions>
                        <BindingCondition Binding="{Binding Design}" Value="DynamicForegroundDark" />
                        <BindingCondition Binding="{Binding IsChecked}" Value="true" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
                </MultiTrigger>
                <DataTrigger TargetType="Border" Binding="{Binding Design}" Value="StaticForeground">
                    <Setter Property="Background" Value="{StaticResource ForegroundBrush}" />
                </DataTrigger>
                <DataTrigger TargetType="Border" Binding="{Binding Design}" Value="StaticForegroundCyan">
                    <Setter Property="Background" Value="{StaticResource ForegroundCyanBrush}" />
                </DataTrigger>
                <DataTrigger TargetType="Border" Binding="{Binding Design}" Value="StaticForegroundBlue">
                    <Setter Property="Background" Value="{StaticResource ForegroundBlueBrush}" />
                </DataTrigger>
                <DataTrigger TargetType="Border" Binding="{Binding Design}" Value="StaticForegroundPurple">
                    <Setter Property="Background" Value="{StaticResource ForegroundPurpleBrush}" />
                </DataTrigger>
                <DataTrigger TargetType="Border" Binding="{Binding Design}" Value="StaticForegroundMagenta">
                    <Setter Property="Background" Value="{StaticResource ForegroundMagentaBrush}" />
                </DataTrigger>
                <DataTrigger TargetType="Border" Binding="{Binding Design}" Value="StaticForegroundRed">
                    <Setter Property="Background" Value="{StaticResource ForegroundRedBrush}" />
                </DataTrigger>
                <DataTrigger TargetType="Border" Binding="{Binding Design}" Value="StaticForegroundOrange">
                    <Setter Property="Background" Value="{StaticResource ForegroundOrangeBrush}" />
                </DataTrigger>
                <DataTrigger TargetType="Border" Binding="{Binding Design}" Value="StaticForegroundGreen">
                    <Setter Property="Background" Value="{StaticResource ForegroundGreenBrush}" />
                </DataTrigger>
            </Border.Triggers>
            
            <Label FontSize="{Binding FontSize}"
                   FontFamily="FontAwSolid"
                   FontAttributes="Bold"
                   TextColor="{Binding TextColorChecked}"
                   Margin="0" 
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center">
                <Label.Triggers>
                    <DataTrigger TargetType="Label" Binding="{Binding IsChecked}" Value="false">
                        <Setter Property="Text" Value=" " />
                    </DataTrigger>
                    <DataTrigger TargetType="Label" Binding="{Binding IsChecked}" Value="true">
                        <Setter Property="Text" Value="&#xf00c;" />
                    </DataTrigger>
                </Label.Triggers>
            </Label>
        </Border>
        <!--<Frame ZIndex="3" BackgroundColor="Transparent" Padding="0">
            <Button Opacity="0" Clicked="Button_Clicked" />
        </Frame>-->
    </Grid>
</ContentView>
