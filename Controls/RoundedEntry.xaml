<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ChecklistApp.Controls"
             x:Name="this"
             x:Class="ChecklistApp.Controls.RoundedEntry"
             x:DataType="controls:RoundedEntry">
    <Frame BindingContext="{x:Reference this}"
           IsClippedToBounds="True"
           BackgroundColor="{StaticResource ForegroundDark}"
           Padding="0">
        <Entry Text="{Binding Text}" 
               Keyboard="{Binding Keyboard}"
               Style="{StaticResource TextEntry}" 
               Placeholder="{Binding Placeholder}" 
               PlaceholderColor="{StaticResource TextDark}" />
    </Frame>
</ContentView>
