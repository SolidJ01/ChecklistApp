<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Name="this"
             x:Class="ChecklistApp.Controls.DateTimePicker">
    <Border BindingContext="{x:Reference this}"
            BackgroundColor="{StaticResource ForegroundDark}">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding Use}" Value="false">
                        <Setter Property="Background" Value="transparent" />
                        <Setter Property="Padding" Value="0" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid ColumnDefinitions="*,*"
              ColumnSpacing="10"
              Padding="5,0">
            <DatePicker Grid.Column="0" 
                        Date="{Binding Date, Mode=TwoWay}" 
                        TextColor="{StaticResource Text}" 
                        FontAttributes="Bold"
                        FontSize="18"
                        VerticalOptions="Center"
                        IsVisible="{Binding Use}" />
            <TimePicker Grid.Column="1" Time="{Binding Time, Mode=TwoWay}" 
                        TextColor="{StaticResource Text}" 
                        FontAttributes="Bold"
                        FontSize="18"
                        VerticalOptions="Center"
                        IsVisible="{Binding Use}" />
            <Label Grid.Column="0" 
                   Grid.ColumnSpan="2" 
                   Text="Deadline"
                   TextColor="{StaticResource Text}" 
                   FontSize="22" 
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Start"
                   VerticalTextAlignment="Center"
                   Margin="0,0"
                   IsVisible="{Binding Use, Converter={StaticResource BooleanInverter}}">
            </Label>
        </Grid>
    </Border>
</ContentView>
